{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "arcana-community",
  "description": "The self-improving AI agent — skills, memory, gateway, coding, and cron in one CLI",
  "private": true,
  "version": "0.2.25",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "postinstall": "node scripts/fix-ai.js",
    "dev": "bun packages/arcana/src/index.ts",
    "dev:tui": "bun --cwd packages/tui dev",
    "dev:web": "bun --cwd packages/app dev",
    "lint": "oxlint",
    "typecheck": "bun turbo typecheck",
    "build": "bun turbo build",
    "test": "bun turbo test",
    "clean": "bun turbo clean"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "packages/sdk/js"
    ],
    "catalog": {
      "@effect/opentelemetry": "4.0.0-beta.74",
      "@effect/platform-node": "4.0.0-beta.74",
      "@effect/sql-sqlite-bun": "4.0.0-beta.74",
      "@npmcli/arborist": "9.4.0",
      "@types/bun": "1.3.13",
      "@types/cross-spawn": "6.0.6",
      "@octokit/rest": "22.0.0",
      "@hono/standard-validator": "0.2.0",
      "@hono/zod-validator": "0.4.2",
      "@opentui/core": "0.3.4",
      "@opentui/keymap": "0.3.4",
      "@opentui/solid": "0.3.4",
      "@tanstack/solid-virtual": "3.13.28",
      "@shikijs/stream": "4.2.0",
      "ulid": "3.0.1",
      "@kobalte/core": "0.13.11",
      "@types/luxon": "3.7.1",
      "@types/node": "24.12.2",
      "@types/semver": "7.7.1",
      "@tsconfig/node22": "22.0.2",
      "@tsconfig/bun": "1.0.9",
      "@cloudflare/workers-types": "4.20251008.0",
      "@pierre/diffs": "1.2.10",
      "opentui-spinner": "0.0.7",
      "@solid-primitives/storage": "4.3.3",
      "@tailwindcss/vite": "4.1.11",
      "diff": "8.0.2",
      "dompurify": "3.3.1",
      "drizzle-kit": "1.0.0-rc.2",
      "drizzle-orm": "1.0.0-rc.2",
      "effect": "4.0.0-beta.74",
      "ai": "6.0.168",
      "@ai-sdk/anthropic": "3.0.82",
      "@ai-sdk/google": "3.0.73",
      "@ai-sdk/openai": "3.0.67",
      "@ai-sdk/openai-compatible": "2.0.47",
      "cross-spawn": "7.0.6",
      "hono": "4.10.7",
      "hono-openapi": "1.1.2",
      "fuzzysort": "3.1.0",
      "luxon": "3.6.1",
      "marked": "17.0.1",
      "marked-shiki": "1.2.1",
      "remend": "1.3.0",
      "semver": "7.7.4",
      "typescript": "5.8.2",
      "zod": "4.1.8",
      "remeda": "2.26.0",
      "shiki": "4.2.0",
      "tailwindcss": "4.1.11",
      "vite": "7.1.4",
      "@solidjs/meta": "0.29.4",
      "@solidjs/router": "0.15.4",
      "solid-js": "1.9.10",
      "solid-list": "0.3.0",
      "vite-plugin-solid": "2.11.10",
      "@solidjs/start": "https://pkg.pr.new/@solidjs/start@dfb2020",
      "@openauthjs/openauth": "0.0.0-20250322224806",
      "@typescript/native-preview": "7.0.0-dev.20251207.1",
      "@lydell/node-pty": "1.2.0-beta.12",
      "gray-matter": "4.0.3",
      "@types/gray-matter": "4.0.3",
      "node-telegram-bot-api": "0.66.0",
      "@types/node-telegram-bot-api": "0.64.8",
      "discord.js": "14.18.0",
      "@slack/bolt": "4.4.0"
    }
  },
  "overrides": {
    "@opencode-ai/plugin": "workspace:*"
  },
  "devDependencies": {
    "@tsconfig/bun": "catalog:",
    "@types/node": "catalog:",
    "oxlint": "1.60.0",
    "prettier": "3.6.2",
    "turbo": "2.9.18"
  },
  "license": "MIT",
  "prettier": {
    "semi": false,
    "printWidth": 120
  },
  "dependencies": {
    "@noble/curves": "2.2.0"
  }
}
