{
  "$schema": "https://raw.githubusercontent.com/Lento47/arcana/master/schema/config.json",
  "provider": {
    "nous-portal": {
      "name": "Nous Portal",
      "npm": "@ai-sdk/openai-compatible",
      "api": "https://portal-api.nousresearch.com/v1",
      "env": ["NOUS_PORTAL_API_KEY"],
      "models": {
        "nous-hermes-3-llama-3.1-70b": {
          "name": "Nous Hermes 3 70B",
          "tool_call": true,
          "limit": { "context": 131072, "output": 4096 }
        }
      }
    },
    "mimo": {
      "name": "MiMo (Xiaomi)",
      "npm": "@ai-sdk/openai-compatible",
      "api": "https://api.xiaomimimo.com/v1",
      "env": ["MIMO_API_KEY"],
      "models": {
        "mimo-7b": {
          "name": "MiMo 7B",
          "tool_call": true,
          "limit": { "context": 32768, "output": 4096 }
        }
      }
    }
  }
}
